{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; object-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob: https://images.unsplash.com https://quickchart.io; media-src 'self'; connect-src 'self'; frame-src 'self' https://view.officeapps.live.com; frame-ancestors 'none'; form-action 'self'; manifest-src 'self'; upgrade-insecure-requests"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "accelerometer=(), autoplay=(), browsing-topics=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=(), fullscreen=(self \"https://view.officeapps.live.com\")"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Permitted-Cross-Domain-Policies",
          "value": "none"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/model-watch",
      "schedule": "17 13 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/weekly-screenshots/2025/ai-tools-header.png",
      "destination": "/weekly-screenshots/2025.11.20/ai-tools-header.png",
      "permanent": true
    },
    {
      "source": "/weekly-screenshots/2025/gemini-benchmarks.png",
      "destination": "/weekly-screenshots/2025.11.26/gemini-benchmarks.png",
      "permanent": true
    },
    {
      "source": "/weekly-screenshots/2025/gemini-vs-others.png",
      "destination": "/weekly-screenshots/2025.11.26/gemini-vs-others.png",
      "permanent": true
    },
    {
      "source": "/weekly-screenshots/2025/grok-release.png",
      "destination": "/weekly-screenshots/2025.11.26/grok-release.png",
      "permanent": true
    },
    {
      "source": "/weekly-screenshots/2025/bezos-prometheus.png",
      "destination": "/weekly-screenshots/2025.11.26/bezos-prometheus.png",
      "permanent": true
    },
    {
      "source": "/weekly-screenshots/2025/gemini-economy.png",
      "destination": "/weekly-screenshots/2025.11.26/gemini-economy.png",
      "permanent": true
    },
    {
      "source": "/slideshows/2026.04.29/ai-avalanche/:path*",
      "destination": "/slideshows/2026.04.15/ai-avalanche/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
