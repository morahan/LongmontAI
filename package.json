{
  "name": "longmont-ai",
  "private": true,
  "version": "0.0.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "security:commit": "scripts/security-commit-review.sh staged",
    "security:push": "scripts/security-commit-review.sh push",
    "security:review": "scripts/security-commit-review.sh all",
    "security:agent-review": "codex exec --ephemeral --sandbox read-only 'Use $security-commit-review to review the current local changes for security vulnerabilities only. Do not edit files or mutate the repository. Prioritize exploitable findings with exact file references and minimal fixes.'",
    "security:remediate": "SECURITY_COMMIT_AUTO_FIX=1 scripts/security-commit-review.sh all",
    "security:test-chain": "node scripts/tests/security-review-chain.test.mjs",
    "security:test-runtime": "node scripts/tests/runtime-security-headers.mjs",
    "test:loop-push": "node scripts/tests/loop-push-contract.test.mjs",
    "security:test": "npm run security:test-chain && npm run security:test-runtime",
    "verify:local": "bash scripts/local-ci.sh",
    "hooks:install": "scripts/install-security-hooks.sh",
    "content:check-assets": "node scripts/check-content-assets.js",
    "model-watch:update": "node scripts/update-model-watch.mjs",
    "test:model-watch": "node scripts/tests/model-watch-contract.test.mjs",
    "test:mobile-contract": "node scripts/tests/mobile-audit-contract.test.mjs",
    "audit:mobile": "sh -c 'BASE=${MOBILE_AUDIT_BASE_URL:-http://localhost:5173}; mkdir -p output/playwright/mobile-audit && MOBILE_AUDIT_BASE_URL=$BASE ~/.codex/skills/playwright/scripts/playwright_cli.sh open \"$BASE\" --headed && MOBILE_AUDIT_BASE_URL=$BASE ~/.codex/skills/playwright/scripts/playwright_cli.sh run-code --filename scripts/mobile-playwright-audit.js'",
    "test:mobile": "bash scripts/run-mobile-audit.sh",
    "preview": "vite preview"
  },
  "dependencies": {
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4"
  }
}
